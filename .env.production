# Production Environment Variables
# Used for docker-compose deployment

# Application
APP_NAME=Jarvis AI Enterprise Platform
APP_VERSION=2.0.0
DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_change_me
POSTGRES_DB=jarvis_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=jarvis_knowledge
QDRANT_VECTOR_SIZE=1536

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_CHAT=gpt-3.5-turbo
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# N8N
N8N_URL=http://n8n:5678
N8N_API_KEY=
N8N_HOST=n8n
N8N_DB=n8n
N8N_LICENSE_ACTIVATION_KEY=
N8N_ENCRYPTION_KEY=

# JWT
JWT_SECRET_KEY=your_super_secret_key_change_in_production_12345
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# MinIO (Optional)
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jarvis-documents

# RAG
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_MIN_SCORE=0.5

# Paths (Docker internal)
DOCUMENTS_PATH=/app/documents
UPLOADS_PATH=/app/uploads
LOGS_PATH=/app/logs
DATA_PATH=/app/data

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Timezone
TZ=America/Sao_Paulo
GENERIC_TIMEZONE=America/Sao_Paulo
