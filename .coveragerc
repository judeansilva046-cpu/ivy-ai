[run]
branch = True
omit =
    */tests/*
    */test_*.py
    */__main__.py
    */setup.py
    */venv/*
    */.venv/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    except ImportError:

[html]
directory = htmlcov
