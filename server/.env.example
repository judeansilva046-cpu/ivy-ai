# Jarvis AI Environment Variables
# Copy this file to .env and fill in your values

# Application Configuration
APP_NAME=Jarvis AI Enterprise Platform
APP_VERSION=2.0.0
DEBUG=False
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=True

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jarvis_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Qdrant Vector Store Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=jarvis_knowledge
QDRANT_VECTOR_SIZE=1536

# OpenAI Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL_CHAT=gpt-3.5-turbo
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# MinIO Configuration (Object Storage)
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=jarvis-documents

# RAG Settings
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_MIN_SCORE=0.5

# Document Paths
DOCUMENTS_PATH=C:\\JarvisAI\\documents
UPLOADS_PATH=C:\\JarvisAI\\server\\uploads
LOGS_PATH=C:\\JarvisAI\\server\\logs
DATA_PATH=C:\\JarvisAI\\server\\data

# N8N Integration
N8N_URL=http://localhost:5678
N8N_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# N8N License (from main .env)
N8N_LICENSE_ACTIVATION_KEY=SUA_CHAVE_DA_LICENCA
N8N_ENCRYPTION_KEY=c6ab003b-ae38-4f95-8948-87ed5fb5fa32527ffb8e-cfa9-4e4b-ad4e-c9da4c77c20c

# Timezone
TZ=America/Sao_Paulo
GENERIC_TIMEZONE=America/Sao_Paulo
